<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Purchase Order - <%= po.poNumber %></title>
    <style>
        :root {
            --primary: #2C3E50;
            --accent: #48C9B0;
            --bg-light: #F4F7F6;
            --text-main: #2E4053;
            --text-muted: #7F8C8D;
            --border: #D5DBDB;
        }

        @page {
            size: A4;
            margin: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 40px;
            color: var(--text-main);
            background-color: white;
            font-size: 11px;
            line-height: 1.5;
        }

        .po-container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
        }

        /* Header Branding */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .logo-section h1 {
            margin: 0;
            color: var(--primary);
            font-size: 28px;
            letter-spacing: 2px;
            font-weight: 800;
        }

        .logo-section p {
            margin: 5px 0 0 0;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: bold;
            font-size: 10px;
        }

        .po-title {
            text-align: right;
        }

        .po-title h2 {
            margin: 0;
            font-size: 32px;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.8;
        }

        /* Meta Info Bar */
        .meta-bar {
            background-color: var(--primary);
            color: white;
            display: flex;
            padding: 12px 20px;
            border-radius: 4px;
            margin-bottom: 30px;
        }

        .meta-item {
            flex: 1;
        }

        .meta-item label {
            display: block;
            font-size: 9px;
            text-transform: uppercase;
            opacity: 0.7;
            font-weight: bold;
            margin-bottom: 2px;
        }

        .meta-item span {
            font-size: 12px;
            font-weight: bold;
        }

        /* Addresses */
        .address-section {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 40px;
        }

        .address-box {
            flex: 1;
        }

        .address-box h3 {
            font-size: 14px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 5px;
            margin-bottom: 12px;
            color: var(--primary);
            display: inline-block;
            min-width: 120px;
        }

        .address-content {
            font-size: 11px;
            color: var(--text-main);
        }

        .address-content strong {
            display: block;
            margin-bottom: 4px;
            font-size: 12px;
            color: var(--primary);
        }

        /* Table Style */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            overflow: hidden;
            border-radius: 4px;
        }

        thead {
            background-color: var(--primary);
            color: white;
        }

        th {
            padding: 12px 15px;
            text-align: left;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--border);
        }

        .alt-row {
            background-color: var(--bg-light);
        }

        .col-sl { width: 40px; text-align: center; }
        .col-qty { width: 80px; text-align: center; }
        .col-price { width: 120px; text-align: right; }
        .col-total { width: 140px; text-align: right; font-weight: bold; }

        .total-section {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .total-table {
            width: 250px;
            margin-bottom: 0;
        }

        .total-table td {
            border: none;
            padding: 5px 15px;
        }

        .grand-total-row {
            background-color: var(--primary);
            color: white;
            font-size: 16px;
            font-weight: 800;
        }

        .grand-total-row td {
            padding: 15px !important;
        }

        /* Footer */
        .footer {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .terms {
            width: 60%;
        }

        .terms h4 {
            font-size: 10px;
            margin-bottom: 5px;
            color: var(--primary);
            text-transform: uppercase;
        }

        .terms p {
            font-size: 9px;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.4;
        }

        .signatures {
            width: 35%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .sig-box {
            width: 100%;
            height: 60px;
            border-bottom: 1px solid var(--primary);
            margin-bottom: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-style: italic;
            color: var(--text-muted);
        }

        .sig-label {
            font-weight: bold;
            font-size: 10px;
            text-transform: uppercase;
            color: var(--primary);
        }
    </style>
</head>
<body>
    <div class="po-container">
        <!-- Header -->
        <div class="header">
            <div class="logo-section">
                <h1><%= store.name.toUpperCase() %></h1>
                <p>Luxury Jewellery & Craftsmanship</p>
            </div>
            <div class="po-title">
                <h2>Purchase Order</h2>
            </div>
        </div>

        <!-- Meta Bar -->
        <div class="meta-bar">
            <div class="meta-item">
                <label>PO #</label>
                <span><%= po.poNumber %></span>
            </div>
            <div class="meta-item">
                <label>Date</label>
                <span><%= new Date(po.purchaseDate).toLocaleDateString('en-IN') %></span>
            </div>
            <div class="meta-item">
                <label>Terms</label>
                <span>Net 30</span>
            </div>
            <div class="meta-item" style="text-align: right;">
                <label>Status</label>
                <span><%= po.status.toUpperCase() %></span>
            </div>
        </div>

        <!-- Addresses -->
        <div class="address-section">
            <div class="address-box">
                <h3>Billing Address</h3>
                <div class="address-content">
                    <strong><%= store.name %></strong>
                    <%= store.address %><br>
                    <%= store.city %>, <%= store.state %> - <%= store.pincode %><br>
                    Tel: <%= store.phone %>
                </div>
            </div>
            <div class="address-box">
                <h3>Vendor Address</h3>
                <div class="address-content">
                    <strong><%= po.vendor.name %></strong>
                    <%= po.vendor.address || 'Address not listed' %><br>
                    GSTIN: <%= po.vendor.gstin || 'N/A' %><br>
                    Tel: <%= po.vendor.phone %>
                </div>
            </div>
            <div class="address-box">
                <h3>Shipping Address</h3>
                <div class="address-content">
                    <strong><%= store.name %> Warehouse</strong>
                    <%= store.address %><br>
                    <%= store.city %>, <%= store.state %> - <%= store.pincode %><br>
                    Attn: Procurement Dept.
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <table>
            <thead>
                <tr>
                    <th class="col-sl">SL.</th>
                    <th>Item Description</th>
                    <th class="col-qty">Quantity</th>
                    <th class="col-price">Unit Price</th>
                    <th class="col-total">Total</th>
                </tr>
            </thead>
            <tbody>
                <% po.items.forEach((item, index) => { %>
                    <tr class="<%= index % 2 === 1 ? 'alt-row' : '' %>">
                        <td class="col-sl"><%= index + 1 %></td>
                        <td>
                            <strong><%= item.product.name %></strong><br>
                            <span style="font-size: 9px; color: var(--text-muted);">SKU: <%= item.product.sku %> | Category: <%= item.product.category %></span>
                        </td>
                        <td class="col-qty"><%= item.quantity %></td>
                        <td class="col-price">₹<%= item.purchasePrice.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                        <td class="col-total">₹<%= item.totalPrice.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Totals -->
        <div class="total-section">
            <div style="flex: 1; padding-top: 10px;">
                <p style="margin: 0; font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Amount in Words:</p>
                <p style="margin: 0; font-size: 11px; font-weight: bold; color: var(--primary);"><%= amountInWords %></p>
            </div>
            <table class="total-table">
                <tr>
                    <td>Subtotal:</td>
                    <td style="text-align: right;">₹<%= po.totalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                </tr>
                <tr>
                    <td>Tax (GST 3%):</td>
                    <td style="text-align: right;">₹0.00</td>
                </tr>
                <tr class="grand-total-row">
                    <td>TOTAL:</td>
                    <td style="text-align: right;">₹<%= po.totalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                </tr>
            </table>
        </div>

        <!-- Footer -->
        <div class="footer">
            <div class="terms">
                <h4>Terms and Conditions:</h4>
                <p>1. Please include the PO number on all invoices and packaging slips.</p>
                <p>2. We reserve the right to reject items that do not meet quality standards.</p>
                <p>3. Payments will be processed within 30 days of receiving a valid invoice and the goods.</p>
                <p>4. This is a computer-generated document and serves as a formal agreement.</p>
            </div>
            <div class="signatures">
                <div class="sig-box">
                    <%= po.employee.name %>
                </div>
                <div class="sig-label">Authorized Signatory</div>
            </div>
        </div>
    </div>
</body>
</html>
